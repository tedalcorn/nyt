# Raw API data (large, regenerable from NYT API)
data/raw/

# Scrape caches (Wayback HTML, resumable)
cache/

# Python
__pycache__/
*.pyc
*.ipynb

# Static charts (replaced by interactive dashboard)
chart*.png
chart*.jpg
choropleth*.png

# Shapefiles in data/ root (large GIS files; data/ne_world/ is tracked separately)
data/*.shp
data/*.dbf
data/*.prj
data/*.shx
data/*.cpg

# macOS metadata
.DS_Store
data/.DS_Store

# Local automation log
nightly_update.log
logs/

# Working prototypes / scratch files
*_prototype*.html
analyze_headlines.py

# Local release assets (social media exports, etc.)
2026*/

# Original NYT reporter bio photos (removed per legal request)
data/bio_photos/*.jpg

# Everything in bio_photos except the Compressed Illustrations JPGs and manifest
data/bio_photos/Master illustrations/
data/bio_photos/NYT photos/
data/bio_photos/Supporting photos/
data/bio_photos/-Prompt.rtf

# Raw per-year tracker files — build_data.py still writes these as the INPUT
# to build_v2_tracker.py (which packs them into the deployed data/v2/ files),
# but the raw form stopped being deployed at the v2 adoption (2026-06-12).
# Ignoring them keeps the nightly `git add data/` from re-tracking 218MB.
data/tracker_*.json

# Local working files — never commit
*.bak
*.pre_*
data/corrections_overrides.json
~$*

